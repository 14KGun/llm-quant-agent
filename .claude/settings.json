{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(pnpm *)",
      "Bash(npx *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm run lint --if-present 2>/dev/null; pnpm run type-check --if-present 2>/dev/null; exit 0"
          }
        ]
      }
    ]
  }
}
